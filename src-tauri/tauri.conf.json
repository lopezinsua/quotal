{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quotal",
  "version": "0.3.1",
  "identifier": "io.github.lopezinsua.quotal",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Quotal",
        "width": 248,
        "height": 268,
        "minWidth": 52,
        "minHeight": 20,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false,
        "center": false,
        "x": 1600,
        "y": 40
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/lopezinsua/quotal/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI2QkMxNkQwMzQyMzYzQjIKUldTeVl5TTAwQmE4SnFndmZleTJKQTFWQlhJbkhsK28yS3I5R043MFpuUVZnMVlFck1FY2ZkQUMK"
    }
  }
}
